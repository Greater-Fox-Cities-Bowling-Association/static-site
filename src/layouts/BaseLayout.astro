---
import SEO from "../components/SEO.astro";
import theme from "../theme.json";

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishDate?: Date;
  author?: string;
}

const { title, description, image, article, publishDate, author } = Astro.props;

// Build CSS variables from theme
const borderRadiusMap: Record<string, string> = {
  none: "0",
  sm: "0.125rem",
  md: "0.375rem",
  lg: "0.5rem",
  full: "9999px",
};

const fontScalePx = `${16 * (theme.fontScale || 1)}px`;
const themeStyle = [
  `--color-primary: ${theme.primaryColor}`,
  `--color-secondary: ${theme.secondaryColor}`,
  `--font-family: ${theme.fontFamily}, system-ui, sans-serif`,
  `--font-size-base: ${fontScalePx}`,
  `--border-radius: ${borderRadiusMap[theme.borderRadius] ?? "0.375rem"}`,
].join(";");

const layoutClass =
  theme.layoutStyle === "wide"
    ? "max-w-6xl"
    : theme.layoutStyle === "full"
    ? "w-full"
    : "max-w-3xl";
---

<!doctype html>
<html lang="en" style={themeStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      image={image}
      article={article}
      publishDate={publishDate}
      author={author}
    />
    <!-- Theme CSS variables are applied via the style attribute on <html> (= :root) -->
    <style>
      body {
        margin: 0;
        padding: 0;
        background: #fff;
        color: #1a1a1a;
        font-family: var(--font-family, system-ui, sans-serif);
        font-size: var(--font-size-base, 16px);
      }

      a {
        color: var(--color-primary);
      }

      .btn {
        background: var(--color-primary);
        color: #fff;
        border-radius: var(--border-radius);
        padding: 0.5rem 1rem;
        text-decoration: none;
        display: inline-block;
      }
    </style>
  </head>
  <body>
    <header class="border-b border-gray-200 py-4">
      <nav class={`mx-auto px-4 flex items-center justify-between ${layoutClass}`}>
        <a href="/" class="text-xl font-bold" style={`color: ${theme.primaryColor}`}>
          My Site
        </a>
        <ul class="flex gap-6 list-none m-0 p-0">
          <li><a href="/" class="text-gray-600 hover:text-gray-900">Home</a></li>
          <li><a href="/blog" class="text-gray-600 hover:text-gray-900">Blog</a></li>
          <li><a href="/admin/" class="text-gray-600 hover:text-gray-900">Admin</a></li>
        </ul>
      </nav>
    </header>

    <main class={`mx-auto px-4 py-8 ${layoutClass}`}>
      <slot />
    </main>

    <footer class="border-t border-gray-200 py-8 mt-16">
      <div class={`mx-auto px-4 text-center text-gray-500 text-sm ${layoutClass}`}>
        <p>&copy; {new Date().getFullYear()} My Site. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
