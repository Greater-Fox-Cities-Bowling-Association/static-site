---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';
import theme from '../theme.json';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const { title, description, image, canonicalURL } = Astro.props;

const settingsEntry = await getEntry('settings', 'main');
const settings = settingsEntry?.data;

// Generate CSS custom properties from theme.json
const themeVars = `
  :root {
    --color-primary: ${theme.primaryColor};
    --color-secondary: ${theme.secondaryColor};
    --font-family: ${theme.fontFamily};
    --font-scale: ${theme.fontScale};
    --border-radius: ${theme.borderRadius};
  }
`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style set:html={themeVars}></style>
    <SEO
      title={title}
      description={description ?? settings?.siteDescription ?? ''}
      image={image}
      canonicalURL={canonicalURL ?? Astro.url.href}
      siteTitle={settings?.siteTitle ?? 'My Static Site'}
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900" style={`font-family: var(--font-family); font-size: calc(1rem * var(--font-scale));`}>
    <Header nav={settings?.nav ?? []} siteTitle={settings?.siteTitle ?? 'My Static Site'} logo={settings?.logo} />
    <main class={`flex-1 w-full mx-auto px-4 py-8 ${theme.layoutStyle === 'centered' ? 'max-w-3xl' : 'max-w-7xl'}`}>
      <slot />
    </main>
    <Footer text={settings?.footer ?? ''} />
  </body>
</html>
