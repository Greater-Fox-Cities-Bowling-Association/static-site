---
import type { ContentListSection, ContentListStyles } from "../../../types/cms";
import type { CollectionDef } from "../../../types/cms";

interface Props {
  section: ContentListSection;
}

const { section } = Astro.props;
const {
  heading,
  collection,
  displayMode,
  itemIds,
  limit,
  columns = 3,
  styles = {} as ContentListStyles,
} = section;

// Resolve a ThemeColorKey token name ("textSecondary") → CSS var ("var(--color-text-secondary)")
function tokenToVar(token: string | undefined): string | undefined {
  if (!token) return undefined;
  const kebab = token.replace(/([A-Z])/g, (m: string) => `-${m.toLowerCase()}`);
  return `var(--color-${kebab})`;
}

// Helper: build an inline style string from style override values (skips undefined)
// Values that are theme token names are automatically resolved to CSS variables.
function s(...pairs: [string, string | undefined][]): string | undefined {
  const parts = pairs
    .map(([k, v]) => [k, tokenToVar(v) ?? v] as [string, string | undefined])
    .filter(([, v]) => v)
    .map(([k, v]) => `${k}:${v}`);
  return parts.length ? parts.join(";") : undefined;
}

// ── Load all items from the collection folder via glob ────────────────────────
// Items live in src/content/collections/{name}/ and are read generically.
const allFiles = import.meta.glob<{ default: Record<string, any> }>(
  "/src/content/collections/**/*.json",
  { eager: true },
);

const prefix = `/src/content/collections/${collection}/`;
let allItems = Object.entries(allFiles)
  .filter(([path]) => path.startsWith(prefix) && path.endsWith(".json"))
  .map(([path, mod]) => ({
    id: path.replace(prefix, "").replace(".json", ""),
    data: mod.default ?? (mod as unknown as Record<string, any>),
  }));

// Filter to specific items if itemIds is provided
if (itemIds && itemIds.length > 0) {
  allItems = allItems.filter((item) => itemIds.includes(item.id));
}

// Apply limit if specified
if (limit && limit > 0) {
  allItems = allItems.slice(0, limit);
}

// ── Load the collection definition to get display field hints ─────────────────
const defFiles = import.meta.glob<{ default: CollectionDef }>(
  "/src/content/collection-defs/*.json",
  { eager: true },
);
const defFile = defFiles[`/src/content/collection-defs/${collection}.json`];
const def: CollectionDef | undefined = defFile
  ? (defFile.default ?? (defFile as unknown as CollectionDef))
  : undefined;

// Determine which field to use as the primary title and summary
const displayField =
  def?.displayField ??
  def?.fields?.find((f) => f.type === "string")?.name ??
  "name";
const summaryField =
  def?.summaryField ??
  def?.fields?.find((f) => f.name === "description" || f.name === "excerpt")
    ?.name ??
  "description";

// ── Generic display mapper (no domain-specific logic) ─────────────────────────
function getItemDisplayData(item: { id: string; data: Record<string, any> }) {
  const d = item.data;
  const title = d[displayField] ?? d.title ?? d.name ?? item.id;
  const description = d[summaryField] ?? d.description ?? d.excerpt ?? "";
  // Use a date/year field as subtitle if present
  const subtitle = d.date ?? (d.year ? String(d.year) : "") ?? "";
  // Build a detail line from the first few non-title string fields
  const details: string[] = [];
  if (def?.fields) {
    for (const f of def.fields) {
      if (
        f.name !== displayField &&
        f.name !== summaryField &&
        f.name !== "date" &&
        f.name !== "year" &&
        (f.type === "string" || f.type === "number") &&
        d[f.name] != null &&
        d[f.name] !== ""
      ) {
        details.push(String(d[f.name]));
        if (details.length >= 3) break;
      }
    }
  }
  return {
    title,
    subtitle,
    description,
    details,
    link: `/${collection}/${item.id}`,
  };
}

const displayItems = allItems.map((item) => ({
  id: item.id,
  ...getItemDisplayData(item),
  rawData: item.data,
}));

const gridColsClass = {
  2: "md:grid-cols-2",
  3: "md:grid-cols-3",
  4: "md:grid-cols-4",
}[columns];
---

<section
  class="py-16 bg-background"
  style={s(["background-color", styles.sectionBg])}
>
  <div class="container mx-auto px-4">
    {
      heading && (
        <h2
          class="text-3xl md:text-4xl font-bold mb-12 text-center text-text"
          style={s(["color", styles.headingColor])}
        >
          {heading}
        </h2>
      )
    }

    {
      displayMode === "cards" && (
        <div class={`grid grid-cols-1 ${gridColsClass} gap-8`}>
          {displayItems.map((item) => (
            <div
              class="bg-background rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow border border-text/10"
              style={s(
                ["background-color", styles.cardBg],
                ["border-color", styles.cardBorder],
              )}
            >
              <div class="p-6">
                <h3
                  class="text-xl font-bold mb-2 text-text"
                  style={s(["color", styles.titleColor])}
                >
                  {item.title}
                </h3>
                {item.subtitle && (
                  <p
                    class="text-sm text-primary font-semibold mb-3"
                    style={s(["color", styles.subtitleColor])}
                  >
                    {item.subtitle}
                  </p>
                )}
                {item.description && (
                  <p
                    class="text-text-secondary mb-4"
                    style={s(["color", styles.bodyColor])}
                  >
                    {item.description}
                  </p>
                )}
                {item.details.length > 0 && (
                  <div
                    class="text-sm text-text-secondary space-y-1 mb-4"
                    style={s(["color", styles.bodyColor])}
                  >
                    {item.details.map((detail) => (
                      <p>{detail}</p>
                    ))}
                  </div>
                )}
                {item.link && (
                  <a
                    href={item.link}
                    class="text-primary hover:text-accent font-semibold inline-flex items-center"
                    style={s(["color", styles.linkColor])}
                    target={item.link.startsWith("http") ? "_blank" : undefined}
                    rel={
                      item.link.startsWith("http")
                        ? "noopener noreferrer"
                        : undefined
                    }
                  >
                    Learn More →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }

    {
      displayMode === "table" && (
        <div class="overflow-x-auto">
          <table class="min-w-full bg-background border border-text/10 rounded-lg overflow-hidden">
            <thead class="bg-primary/10">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-text uppercase tracking-wider">
                  Name
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-text uppercase tracking-wider">
                  Details
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-text uppercase tracking-wider">
                  Actions
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-text/10">
              {displayItems.map((item) => (
                <tr
                  class="hover:bg-primary/5 transition-colors"
                  style={s(["background-color", styles.cardBg])}
                >
                  <td class="px-6 py-4">
                    <div
                      class="text-sm font-medium text-text"
                      style={s(["color", styles.titleColor])}
                    >
                      {item.title}
                    </div>
                    {item.subtitle && (
                      <div
                        class="text-sm text-text-secondary"
                        style={s(["color", styles.subtitleColor])}
                      >
                        {item.subtitle}
                      </div>
                    )}
                  </td>
                  <td class="px-6 py-4">
                    {item.description && (
                      <div
                        class="text-sm text-text-secondary"
                        style={s(["color", styles.bodyColor])}
                      >
                        {item.description}
                      </div>
                    )}
                    {item.details.length > 0 && (
                      <div
                        class="text-xs text-text-secondary space-y-1 mt-1"
                        style={s(["color", styles.bodyColor])}
                      >
                        {item.details.map((detail) => (
                          <div>{detail}</div>
                        ))}
                      </div>
                    )}
                  </td>
                  <td class="px-6 py-4">
                    {item.link && (
                      <a
                        href={item.link}
                        class="text-primary hover:text-accent font-semibold text-sm"
                        style={s(["color", styles.linkColor])}
                        target={
                          item.link.startsWith("http") ? "_blank" : undefined
                        }
                        rel={
                          item.link.startsWith("http")
                            ? "noopener noreferrer"
                            : undefined
                        }
                      >
                        View →
                      </a>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }

    {
      displayMode === "list" && (
        <div class="max-w-4xl mx-auto space-y-6">
          {displayItems.map((item) => (
            <div
              class="bg-background rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow border border-text/10"
              style={s(
                ["background-color", styles.cardBg],
                ["border-color", styles.cardBorder],
              )}
            >
              <div class="flex justify-between items-start">
                <div class="flex-1">
                  <h3
                    class="text-xl font-bold text-text mb-2"
                    style={s(["color", styles.titleColor])}
                  >
                    {item.title}
                  </h3>
                  {item.subtitle && (
                    <p
                      class="text-sm text-primary font-semibold mb-2"
                      style={s(["color", styles.subtitleColor])}
                    >
                      {item.subtitle}
                    </p>
                  )}
                  {item.description && (
                    <p
                      class="text-text-secondary mb-3"
                      style={s(["color", styles.bodyColor])}
                    >
                      {item.description}
                    </p>
                  )}
                  {item.details.length > 0 && (
                    <div
                      class="text-sm text-text-secondary space-y-1"
                      style={s(["color", styles.bodyColor])}
                    >
                      {item.details.map((detail) => (
                        <p>{detail}</p>
                      ))}
                    </div>
                  )}
                </div>
                {item.link && (
                  <a
                    href={item.link}
                    class="ml-4 text-primary hover:text-accent font-semibold text-sm whitespace-nowrap"
                    style={s(["color", styles.linkColor])}
                    target={item.link.startsWith("http") ? "_blank" : undefined}
                    rel={
                      item.link.startsWith("http")
                        ? "noopener noreferrer"
                        : undefined
                    }
                  >
                    View →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      )
    }

    {
      displayItems.length === 0 && (
        <div class="text-center py-12">
          <p class="text-text-secondary">No items to display.</p>
        </div>
      )
    }
  </div>
</section>
