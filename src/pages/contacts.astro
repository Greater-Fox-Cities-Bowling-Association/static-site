---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../content/contacts/contacts.json";

interface Officer {
  name: string;
  title: string;
}
---

<BaseLayout
  title={data.heading}
  description="Contact the Greater Fox Cities USBC Bowling Association — officers, board members, email and social links."
>
  <div class="contacts-page">
    <h1>{data.heading}</h1>

    <!-- Connect section -->
    <section class="connect-section">
      <h2>Connect With Us</h2>
      <div class="connect-cards">
        <div class="connect-card">
          <span class="connect-icon">✉️</span>
          <div>
            <strong>Email</strong>
            <ul class="email-list">
              {
                data.emails.map((email: string) => (
                  <li>
                    <a href={`mailto:${email}`}>{email}</a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
        <div class="connect-card">
          <span class="connect-icon">📘</span>
          <div>
            <strong>Facebook</strong>
            <p>
              <a
                href={data.facebook_url}
                target="_blank"
                rel="noopener noreferrer"
              >
                {data.facebook_label}
              </a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Officers -->
    <section class="officers-section">
      <h2>Association Officers</h2>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Title</th>
          </tr>
        </thead>
        <tbody>
          {
            data.officers.map((officer: Officer, i: number) => (
              <tr class={i % 2 === 0 ? "even" : "odd"}>
                <td>{officer.name}</td>
                <td>{officer.title}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </section>

    <!-- Board of Directors -->
    <section class="board-section">
      <h2>Board of Directors</h2>
      <ul class="board-list">
        {data.board.map((name: string) => <li>{name}</li>)}
      </ul>
      {
        data.vacancies_note && (
          <p class="vacancy-note">⚠️ {data.vacancies_note}</p>
        )
      }
    </section>

    <!-- Join Us -->
    <section class="join-section">
      <p>{data.board_appeal}</p>
      <a
        href={data.application_link_url}
        target="_blank"
        rel="noopener noreferrer"
        class="apply-btn"
      >
        Download Application Form
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .contacts-page {
    max-width: var(--max-w, 960px);
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    color: var(--navy);
    border-bottom: 3px solid var(--red);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  h2 {
    color: var(--navy);
    font-size: 1.2rem;
    margin-bottom: 0.85rem;
  }

  section {
    background: #fff;
    border: 1px solid var(--border, #ddd);
    border-top: 3px solid var(--navy);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* Connect */
  .connect-cards {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .connect-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    background: var(--cream, #f7f3ec);
    border-radius: 4px;
    padding: 0.85rem 1rem;
    min-width: 220px;
    flex: 1;
  }

  .connect-icon {
    font-size: 1.5rem;
    line-height: 1;
    margin-top: 0.1rem;
  }

  .connect-card strong {
    display: block;
    color: var(--navy);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.35rem;
  }

  .email-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .email-list li + li {
    margin-top: 0.25rem;
  }

  .connect-card a,
  .email-list a {
    color: var(--red, #c8102e);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .connect-card a:hover,
  .email-list a:hover {
    text-decoration: underline;
  }

  .connect-card p {
    margin: 0;
  }

  /* Officers table */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  thead tr {
    background: var(--navy);
    color: #fff;
  }

  th {
    padding: 0.6rem 0.9rem;
    text-align: left;
    font-weight: 600;
  }

  td {
    padding: 0.55rem 0.9rem;
  }

  tr.even td {
    background: var(--cream, #f7f3ec);
  }

  tr.odd td {
    background: #fff;
  }

  /* Board */
  .board-list {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
  }

  .board-list li {
    background: var(--cream, #f7f3ec);
    padding: 0.3rem 0.7rem;
    border-radius: 3px;
    font-size: 0.9rem;
    color: #333;
  }

  .vacancy-note {
    margin: 0.5rem 0 0;
    font-size: 0.9rem;
    color: var(--red, #c8102e);
    font-weight: 600;
  }

  /* Join */
  .join-section {
    border-top-color: var(--red);
  }

  .join-section p {
    margin: 0 0 1rem;
    color: #333;
    line-height: 1.6;
  }

  .apply-btn {
    display: inline-block;
    background: var(--red, #c8102e);
    color: #fff;
    padding: 0.6rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .apply-btn:hover {
    background: var(--red-dark, #a00d24);
  }
</style>
