---
// src/pages/admin/index.astro
// Injects Auth0 config from environment variables, then loads Decap CMS.
const auth0Domain   = import.meta.env.PUBLIC_AUTH0_DOMAIN   ?? '';
const auth0ClientId = import.meta.env.PUBLIC_AUTH0_CLIENT_ID ?? '';
const siteUrl       = import.meta.env.PUBLIC_SITE_URL        ?? '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CMS Admin</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="cms-config-url" type="application/json" href="/admin/config.yml" />
    <style>
      #auth-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        font-family: system-ui, sans-serif;
        color: #374151;
      }
      #auth-loading h2 { margin-bottom: 0.5rem; }
      #auth-loading p  { color: #6b7280; font-size: 0.9rem; }
    </style>
  </head>
  <body>
    <div id="auth-loading" style="display:none">
      <h2>Checking authentication…</h2>
      <p>You will be redirected to login if needed.</p>
    </div>

    <!-- Auth0 config injected at build time from environment variables -->
    <script is:inline define:vars={{ auth0Domain, auth0ClientId, siteUrl }}>
      window.__AUTH0_CONFIG__ = {
        domain:      auth0Domain,
        clientId:    auth0ClientId,
        redirectUri: (siteUrl || window.location.origin) + '/admin/',
      };
    </script>

    <!-- Auth0 SPA SDK -->
    <script is:inline src="https://cdn.auth0.com/js/auth0-spa-js/2.1/auth0-spa-js.production.js"></script>

    <!-- Auth0 guard: validates session, extracts GITHUB_PAT, dispatches auth0:ready -->
    <script is:inline src="/admin/auth.js"></script>

    <!-- Load Decap CMS only after auth0:ready fires -->
    <script is:inline>
      console.log('[index.astro] addEventListener for auth0:ready registered');

      function onAuthReady(token) {
        console.log('[index.astro] onAuthReady called, token present:', !!token);
        var githubToken = token;

        // Fetch the GitHub user profile with the PAT first.
        // Decap's LocalStorageAuthStore.retrieve() checks that backendName === 'github'
        // before calling restoreUser() → authenticate(). Doing this fetch here means
        // Decap finds a fully-populated `decap-cms-user` entry on startup and skips
        // the login screen entirely.
        fetch('https://api.github.com/user', {
          headers: { Authorization: 'Bearer ' + githubToken }
        })
        .then(function (res) { return res.json(); })
        .then(function (ghUser) {
          console.log('[index.astro] GitHub user fetched:', ghUser.login);
          window.localStorage.setItem('decap-cms-user', JSON.stringify({
            token:       githubToken,
            backendName: 'github',
            login:       ghUser.login,
            name:        ghUser.name || ghUser.login,
            avatar_url:  ghUser.avatar_url,
            url:         ghUser.url,
          }));

          var loadingEl = document.getElementById('auth-loading');
          if (loadingEl) loadingEl.remove();
          console.log('[index.astro] loading Decap CMS script');

          var decap = document.createElement('script');
          decap.src = 'https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js';
          document.body.appendChild(decap);

          decap.onload = function () {
            console.log('[index.astro] Decap CMS loaded, loading csv-import widget');
            var widget = document.createElement('script');
            widget.src = '/admin/widgets/csv-import.js';
            document.body.appendChild(widget);

            // Load CMS customisations (preview templates, editor components, branding)
            widget.onload = function () {
              console.log('[index.astro] CSV widget loaded, loading CMS customisations');
              var custom = document.createElement('script');
              custom.src = '/admin/cms-customizations.js';
              document.body.appendChild(custom);
            };
          };
        })
        .catch(function (err) {
          console.error('[index.astro] GitHub API error:', err);
          var el = document.getElementById('auth-loading');
          if (el) {
            el.style.display = 'flex';
            el.innerHTML =
              '<h2 style="color:#dc2626">GitHub API error</h2>' +
              '<p>Could not fetch GitHub user with the provided PAT: ' + err.message + '</p>';
          }
        });
      }

      // If auth.js already ran and set the token before this script registered,
      // call onAuthReady immediately; otherwise wait for the event.
      if (window.__auth0Token) {
        console.log('[index.astro] window.__auth0Token already set, calling onAuthReady immediately');
        onAuthReady(window.__auth0Token);
      } else {
        window.addEventListener('auth0:ready', function (e) {
          console.log('[index.astro] auth0:ready event received');
          onAuthReady(e.detail.token);
        });
      }
    </script>
  </body>
</html>
