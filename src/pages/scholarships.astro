---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../content/scholarships/scholarships.json";
---

<BaseLayout
  title={data.heading}
  description="GFCBA scholarship application forms and eligibility information."
>
  <div class="scholarships-page">
    <h1>{data.heading}</h1>

    <div class="intro-box">
      <p>{data.intro}</p>
    </div>

    <div class="links-section">
      <h2>Scholarship Application Forms</h2>
      <ul class="link-list">
        {
          data.links.map((link: { label: string; url: string }) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                <span class="icon">📄</span> {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</BaseLayout>

<style>
  .scholarships-page {
    max-width: var(--max-w, 960px);
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    color: var(--navy);
    border-bottom: 3px solid var(--red);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  h2 {
    color: var(--navy);
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .intro-box {
    background: var(--cream, #f7f3ec);
    border-left: 4px solid var(--navy);
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    border-radius: 0 4px 4px 0;
  }

  .intro-box p {
    margin: 0;
    color: #333;
    line-height: 1.6;
  }

  .links-section {
    background: #fff;
    border: 1px solid var(--border, #ddd);
    border-top: 3px solid var(--navy);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .link-list a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--navy);
    color: #fff;
    padding: 0.65rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.95rem;
    transition: background 0.2s;
    width: fit-content;
  }

  .link-list a:hover {
    background: var(--red);
  }
</style>
