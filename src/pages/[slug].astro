---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import type { ContentPage } from "../../cms/types";

export const getStaticPaths: GetStaticPaths = async () => {
  const pages = await import.meta.glob<{ default: ContentPage }>(
    "/src/content/pages/*.json"
  );

  const paths = await Promise.all(
    Object.values(pages).map(async (load) => {
      const mod = await load();
      const page = mod.default;
      return {
        params: { slug: page.slug },
        props: { page },
      };
    })
  );

  return paths;
};

const { page } = Astro.props as { page: ContentPage };
---

<BaseLayout title={page.title} description={page.description}>
  <main style="max-width: 860px; margin: 2rem auto; padding: 0 1rem;">
    {page.body ? (
      <div set:html={page.body} />
    ) : (
      <h1>{page.title}</h1>
    )}
  </main>
</BaseLayout>