---
import BaseLayout from "../layouts/BaseLayout.astro";
import data from "../content/awards.json";
---

<BaseLayout
  title={data.heading}
  description="GFCBA award information, eligibility rules, and application forms."
>
  <div class="awards-page">
    <h1>{data.heading}</h1>

    <div class="links-box">
      <h2>Award Forms</h2>
      <ul class="link-list">
        {
          data.links.map((link: { label: string; url: string }) => (
            <li>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="rules-box">
      <h2>Award Eligibility Rules</h2>
      <dl>
        <dt>Who</dt>
        <dd>{data.rules.who}</dd>
        <dt>When</dt>
        <dd>{data.rules.when}</dd>
        <dt>Where</dt>
        <dd>{data.rules.where}</dd>
      </dl>
    </div>

    {
      data.award_groups.map((group: { title: string; awards: string[] }) => (
        <div class="award-group">
          <h2>{group.title}</h2>
          <ul>
            {group.awards.map((award: string) => (
              <li>{award}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</BaseLayout>

<style>
  .awards-page {
    max-width: var(--max-w, 960px);
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    color: var(--navy);
    border-bottom: 3px solid var(--red);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  h2 {
    color: var(--navy);
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .links-box,
  .rules-box,
  .award-group {
    background: #fff;
    border: 1px solid var(--border, #ddd);
    border-top: 3px solid var(--navy);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .link-list a {
    display: inline-block;
    background: var(--navy);
    color: #fff;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.9rem;
    transition: background 0.2s;
  }

  .link-list a:hover {
    background: var(--red);
  }

  dl {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: 0.5rem 1rem;
    margin: 0;
  }

  dt {
    font-weight: 700;
    color: var(--navy);
    align-self: start;
  }

  dd {
    margin: 0;
    color: #333;
  }

  .award-group ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin: 0;
  }

  .award-group li {
    margin-bottom: 0.35rem;
    color: #333;
  }
</style>
