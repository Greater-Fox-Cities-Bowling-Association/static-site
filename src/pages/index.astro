---
import BaseLayout from "../layouts/BaseLayout.astro";
import { isVersioned, resolvePublished } from "../../cms/types";
import homeRaw from "../content/home/home.json";

// Resolve the published version if the file uses versioning; otherwise use raw.
const home = isVersioned(homeRaw)
  ? resolvePublished(homeRaw)
  : (homeRaw as Record<string, unknown>);

const siteName = "Greater Fox Cities Bowling Association";
const title = (home["title"] as string | undefined) ?? siteName;
const description =
  (home["description"] as string | undefined) ??
  (home["hero_text"] as string | undefined) ??
  "Welcome to the Greater Fox Cities Bowling Association.";
const hero_text = home["hero_text"] as string | undefined;
const body = home["body"] as string | undefined;
---

<BaseLayout title="Home" description={description}>
  {
    body ? (
      <div set:html={body} />
    ) : hero_text ? (
      <p style="font-size: 1.05rem; line-height: 1.7;">{hero_text}</p>
    ) : (
      <h1>{siteName}</h1>
    )
  }
</BaseLayout>
