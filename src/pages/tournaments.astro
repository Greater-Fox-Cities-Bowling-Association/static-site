---
import BaseLayout from "../layouts/BaseLayout.astro";
import tournamentsRaw from "../content/tournaments/tournaments.json";

interface TournamentEntry {
  name?: string;
  dates?: string;
  location?: string;
  description?: string;
  entry_fee?: string;
  status?: string;
}

const data = tournamentsRaw as {
  slug?: string;
  heading?: string;
  intro?: string;
  current_season?: string;
  tournaments?: TournamentEntry[];
};

const pageTitle = data.heading ?? "Association Tournaments";
const season = data.current_season;
const tournaments = data.tournaments ?? [];

// Separate status groups for optional future use — currently all rendered together
const hasFee = tournaments.some((t) => t.entry_fee);
---

<BaseLayout
  title={pageTitle}
  description={data.intro ??
    "View the current tournament schedule for the Greater Fox Cities Bowling Association."}
>
  <h1>{pageTitle}</h1>

  {data.intro && <p class="tournaments-intro">{data.intro}</p>}

  {
    season && (
      <p class="season-label">
        Season: <strong>{season}</strong>
      </p>
    )
  }

  {
    tournaments.length > 0 ? (
      <ul class="tournament-list">
        {tournaments.map((t) => (
          <li class="tournament-card">
            <div class="tournament-card__header">
              {t.name && (
                <strong class="tournament-card__name">{t.name}</strong>
              )}
              {t.status && (
                <span
                  class={`tournament-card__status status--${(t.status ?? "").toLowerCase().replace(/\s+/g, "-")}`}
                >
                  {t.status}
                </span>
              )}
            </div>
            <dl class="tournament-card__meta">
              {t.dates && (
                <>
                  <dt>Dates</dt>
                  <dd>{t.dates}</dd>
                </>
              )}
              {t.location && (
                <>
                  <dt>Location</dt>
                  <dd>{t.location}</dd>
                </>
              )}
              {t.entry_fee && (
                <>
                  <dt>Entry Fee</dt>
                  <dd>{t.entry_fee}</dd>
                </>
              )}
            </dl>
            {t.description && (
              <p class="tournament-card__desc">{t.description}</p>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p>No tournaments have been scheduled yet. Check back soon.</p>
    )
  }
</BaseLayout>

<style>
  .tournaments-intro {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 0.25rem;
  }

  .season-label {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .tournament-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tournament-card {
    background: var(--cream);
    border-left: 5px solid var(--red);
    border-radius: 0 6px 6px 0;
    padding: 1rem 1.25rem;
  }

  .tournament-card__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }

  .tournament-card__name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--navy);
  }

  .tournament-card__status {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
    background: var(--navy-light);
    color: #c8d6f5;
    white-space: nowrap;
  }

  .tournament-card__status.status--registration-open {
    background: #145a32;
    color: #a9dfbf;
  }

  .tournament-card__status.status--completed {
    background: #555;
    color: #ddd;
  }

  .tournament-card__meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1rem;
    row-gap: 0.2rem;
    margin: 0;
    font-size: 0.875rem;
  }

  .tournament-card__meta dt {
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .tournament-card__meta dd {
    margin: 0;
    color: var(--text);
  }

  .tournament-card__desc {
    margin: 0.75rem 0 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-muted);
  }
</style>
