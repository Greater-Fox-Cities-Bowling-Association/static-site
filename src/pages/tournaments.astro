---
import BaseLayout from "../layouts/BaseLayout.astro";
import tournamentsRaw from "../content/tournaments/tournaments.json";

interface TournamentLink {
  label?: string;
  url?: string;
}

interface TournamentEntry {
  name?: string;
  dates?: string;
  location?: string;
  links?: TournamentLink[];
}

const data = tournamentsRaw as {
  slug?: string;
  heading?: string;
  intro?: string;
  current_season?: string;
  tournaments?: TournamentEntry[];
};

const pageTitle = data.heading ?? "Association Tournaments";
const season = data.current_season;
const tournaments = data.tournaments ?? [];
---

<BaseLayout
  title={pageTitle}
  description={data.intro ??
    "View the current tournament schedule for the Greater Fox Cities Bowling Association."}
>
  <h1>{pageTitle}</h1>

  {data.intro && <p class="tournaments-intro">{data.intro}</p>}

  {
    season && (
      <p class="season-label">
        Season: <strong>{season}</strong>
      </p>
    )
  }

  {
    tournaments.length > 0 ? (
      <ul class="tournament-list">
        {tournaments.map((t) => (
          <li class="tournament-card">
            <strong class="tournament-card__name">{t.name}</strong>
            <dl class="tournament-card__meta">
              {t.dates && (
                <>
                  <dt>Dates</dt>
                  <dd>{t.dates}</dd>
                </>
              )}
              {t.location && (
                <>
                  <dt>Location</dt>
                  <dd>{t.location}</dd>
                </>
              )}
            </dl>
            {(t.links ?? []).length > 0 && (
              <ul class="tournament-card__links">
                {(t.links ?? []).map((lk) => (
                  <li>
                    <a
                      href={lk.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="tournament-card__link"
                    >
                      {lk.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p>No tournaments have been scheduled yet. Check back soon.</p>
    )
  }
</BaseLayout>

<style>
  .tournaments-intro {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 0.25rem;
  }

  .season-label {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .tournament-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tournament-card {
    background: var(--cream);
    border-left: 5px solid var(--red);
    border-radius: 0 6px 6px 0;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tournament-card__name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--navy);
  }

  .tournament-card__meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1rem;
    row-gap: 0.15rem;
    margin: 0;
    font-size: 0.875rem;
  }

  .tournament-card__meta dt {
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .tournament-card__meta dd {
    margin: 0;
    color: var(--text);
  }

  .tournament-card__links {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.75rem;
  }

  .tournament-card__link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--red);
    text-decoration: none;
  }

  .tournament-card__link:hover {
    color: var(--red-dark);
    text-decoration: underline;
  }

  .tournament-card__link::before {
    content: "↗ ";
    font-size: 0.75rem;
    opacity: 0.7;
  }
</style>
