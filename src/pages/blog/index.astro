---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog" description="All posts">
  <h1 class="text-3xl font-bold mb-8">Blog</h1>
  {posts.length === 0 && <p class="text-gray-500">No posts yet. Add some via the CMS!</p>}
  <ul class="space-y-6 list-none p-0">
    {posts.map((post) => (
      <li class="border-b border-gray-100 pb-6">
        <a href={`/blog/${post.slug}/`} class="group">
          <h2 class="text-xl font-semibold group-hover:text-primary transition-colors">
            {post.data.title}
          </h2>
          <p class="text-sm text-gray-500 mt-1">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            {post.data.author && ` · ${post.data.author}`}
          </p>
          {post.data.description && (
            <p class="text-gray-700 mt-2">{post.data.description}</p>
          )}
          {post.data.tags?.length > 0 && (
            <div class="flex gap-2 mt-2 flex-wrap">
              {post.data.tags.map(tag => (
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          )}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
