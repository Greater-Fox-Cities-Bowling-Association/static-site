---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  let posts: Awaited<ReturnType<typeof getCollection<"posts">>> = [];
  try {
    posts = await getCollection("posts");
  } catch {
    return [];
  }
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title} — My Site`}
  description={post.data.description}
  article={true}
  publishDate={post.data.publishDate}
  author={post.data.author}
>
  <article>
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-3">{post.data.title}</h1>
      {
        post.data.publishDate && (
          <time
            class="text-gray-400 text-sm"
            datetime={post.data.publishDate.toISOString()}
          >
            {post.data.publishDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
        )
      }
      {post.data.author && <p class="text-gray-500 mt-1">By {post.data.author}</p>}
    </header>

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <div class="mt-12">
      <a href="/blog" class="text-blue-600 hover:underline">&larr; Back to Blog</a>
    </div>
  </article>
</BaseLayout>
