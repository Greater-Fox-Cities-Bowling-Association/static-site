---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
>
  <article class="prose prose-blue max-w-none">
    <header class="not-prose mb-8">
      <h1 class="text-3xl font-bold">{post.data.title}</h1>
      <p class="text-sm text-gray-500 mt-2">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        {post.data.author && ` · ${post.data.author}`}
      </p>
      {post.data.tags?.length > 0 && (
        <div class="flex gap-2 mt-3 flex-wrap">
          {post.data.tags.map(tag => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <Content />
  </article>
  <div class="mt-8 pt-4 border-t border-gray-200">
    <a href="/blog/" class="text-primary hover:underline text-sm">← Back to Blog</a>
  </div>
</BaseLayout>
