# ─────────────────────────────────────────────────────────────────────────────
# Static Site Template — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
# Full URL of your deployed site (no trailing slash)
PUBLIC_SITE_URL=https://your-domain.com

# ── GitHub Backend (Decap CMS) ────────────────────────────────────────────────
# Repository in the format: owner/repo
PUBLIC_GITHUB_REPO=YOUR_GITHUB_USERNAME/YOUR_REPO_NAME

# Branch Decap CMS commits to
PUBLIC_GITHUB_BRANCH=main

# OAuth base URL — use https://api.netlify.com for Netlify OAuth,
# or your own oauth-provider URL if self-hosting
PUBLIC_GITHUB_BASE_URL=https://api.netlify.com

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Auth0 Application type: Single Page Application
# Allowed Callback URLs : https://your-domain.com/admin/
# Allowed Logout URLs   : https://your-domain.com/
# Allowed Web Origins   : https://your-domain.com

# Your Auth0 tenant domain  e.g. dev-xxxx.us.auth0.com
PUBLIC_AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN

# SPA Application Client ID from the Auth0 dashboard
PUBLIC_AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
