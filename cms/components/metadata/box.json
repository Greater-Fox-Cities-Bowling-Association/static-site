{
  "id": "box",
  "name": "Box",
  "category": "primitive",
  "props": {
    "padding": { "type": "spacing", "default": 0 },
    "margin": { "type": "spacing", "default": 0 },
    "backgroundColor": { "type": "color", "default": "transparent" },
    "borderRadius": { "type": "radius", "default": "none" },
    "display": { "type": "string", "default": "block" },
    "width": { "type": "string", "default": "auto" },
    "height": { "type": "string", "default": "auto" }
  },
  "slots": {
    "children": { "allowedTypes": ["*"], "max": 100 }
  },
  "events": {},
  "theme": {
    "usesColors": true,
    "usesSpacing": true,
    "usesRadius": true,
    "usesTypography": false,
    "usesShadow": false
  },
  "editor": {
    "icon": "crop_square",
    "previewHeight": 80,
    "draggable": true,
    "resizable": true
  }
}
