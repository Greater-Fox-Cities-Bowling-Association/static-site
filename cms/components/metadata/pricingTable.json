{
  "id": "pricingTable",
  "name": "Pricing Table",
  "category": "composite",
  "props": {
    "heading": { "type": "string", "default": "Pricing" },
    "plans": {
      "type": "array",
      "default": [],
      "itemShape": {
        "name": { "type": "string", "default": "Plan" },
        "price": { "type": "string", "default": "$0" },
        "period": { "type": "string", "default": "/month" },
        "ctaLabel": { "type": "string", "default": "Get Started" },
        "ctaHref": { "type": "string", "default": "#" },
        "highlighted": { "type": "boolean", "default": false }
      }
    }
  },
  "slots": {},
  "events": {},
  "theme": {
    "usesColors": true,
    "usesTypography": true,
    "usesSpacing": true,
    "usesRadius": true,
    "usesShadow": true
  },
  "editor": {
    "icon": "attach_money",
    "previewHeight": 400,
    "draggable": true,
    "resizable": false
  }
}
