{
  "id": "icon",
  "name": "Icon",
  "category": "primitive",
  "props": {
    "name": { "type": "string", "default": "star" },
    "fontSize": { "type": "string", "options": ["small","medium","large","inherit"], "default": "medium" },
    "color": { "type": "string", "options": ["inherit","primary","secondary","action","disabled","error"], "default": "inherit" }
  },
  "slots": {},
  "events": {},
  "theme": {
    "usesColors": true,
    "usesTypography": false,
    "usesSpacing": false,
    "usesRadius": false,
    "usesShadow": false
  },
  "editor": {
    "icon": "interests",
    "previewHeight": 40,
    "draggable": true,
    "resizable": false
  }
}
