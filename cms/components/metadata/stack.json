{
  "id": "stack",
  "name": "Stack",
  "category": "primitive",
  "props": {
    "direction": { "type": "string", "options": ["row", "column", "row-reverse", "column-reverse"], "default": "column" },
    "spacing": { "type": "spacing", "default": 2 },
    "alignItems": { "type": "string", "options": ["flex-start", "center", "flex-end", "stretch"], "default": "flex-start" },
    "justifyContent": { "type": "string", "options": ["flex-start", "center", "flex-end", "space-between", "space-around"], "default": "flex-start" }
  },
  "slots": {
    "children": { "allowedTypes": ["*"], "max": 50 }
  },
  "events": {},
  "theme": {
    "usesColors": false,
    "usesSpacing": true,
    "usesRadius": false,
    "usesTypography": false,
    "usesShadow": false
  },
  "editor": {
    "icon": "view_stream",
    "previewHeight": 120,
    "draggable": true,
    "resizable": true
  }
}
