{
  "id": "image",
  "name": "Image",
  "category": "primitive",
  "props": {
    "src": { "type": "string", "default": "" },
    "alt": { "type": "string", "default": "Image" },
    "width": { "type": "string", "default": "100%" },
    "height": { "type": "string", "default": "auto" },
    "objectFit": { "type": "string", "options": ["cover","contain","fill","none","scale-down"], "default": "cover" },
    "borderRadius": { "type": "radius", "default": "none" }
  },
  "slots": {},
  "events": {
    "onClick": { "type": "action", "default": null }
  },
  "theme": {
    "usesColors": false,
    "usesTypography": false,
    "usesSpacing": false,
    "usesRadius": true,
    "usesShadow": false
  },
  "editor": {
    "icon": "image",
    "previewHeight": 200,
    "draggable": true,
    "resizable": true
  }
}
