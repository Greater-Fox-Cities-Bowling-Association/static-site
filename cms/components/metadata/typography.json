{
  "id": "typography",
  "name": "Typography",
  "category": "primitive",
  "props": {
    "variant": { "type": "string", "options": ["h1","h2","h3","h4","h5","h6","body1","body2","caption","button"], "default": "body1" },
    "text": { "type": "string", "default": "Text content" },
    "align": { "type": "string", "options": ["left","center","right","justify"], "default": "left" },
    "color": { "type": "color", "default": "text.primary" },
    "gutterBottom": { "type": "boolean", "default": false }
  },
  "slots": {},
  "events": {},
  "theme": {
    "usesColors": true,
    "usesTypography": true,
    "usesSpacing": false,
    "usesRadius": false,
    "usesShadow": false
  },
  "editor": {
    "icon": "title",
    "previewHeight": 60,
    "draggable": true,
    "resizable": false
  }
}
