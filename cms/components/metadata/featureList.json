{
  "id": "featureList",
  "name": "Feature List",
  "category": "composite",
  "props": {
    "heading": { "type": "string", "default": "Our Features" },
    "features": {
      "type": "array",
      "default": [],
      "itemShape": {
        "title": { "type": "string", "default": "Feature Title" },
        "body": { "type": "string", "default": "Describe this feature." },
        "icon": { "type": "string", "default": "star" }
      }
    },
    "columns": { "type": "number", "default": 3 }
  },
  "slots": {},
  "events": {},
  "theme": {
    "usesColors": true,
    "usesTypography": true,
    "usesSpacing": true,
    "usesRadius": false,
    "usesShadow": false
  },
  "editor": {
    "icon": "view_list",
    "previewHeight": 280,
    "draggable": true,
    "resizable": false
  }
}
