    { "name": "game_totals", "label": "Game Totals",     "type": "array",  "of": "number", "helpText": "Individual game totals for a series record" },
    { "name": "bowlers",     "label": "Bowlers",         "type": "array",  "ofSchema": "record-bowler" }
  ]
