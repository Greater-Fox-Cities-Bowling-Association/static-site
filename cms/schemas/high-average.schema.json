{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "High Average",
  "type": "object",
  "properties": {
    "heading": { "type": "string" },
    "intro": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "year": { "type": "string" },
          "division": { "type": "string" },
          "bowler": { "type": "string" },
          "games": { "type": "integer" },
          "average": { "type": "number" }
        },
        "required": ["year", "bowler", "average"]
      }
    }
  },
  "required": ["heading", "entries"]
}
