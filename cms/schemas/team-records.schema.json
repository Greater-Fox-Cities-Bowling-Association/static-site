{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Team Records",
  "type": "object",
  "properties": {
    "heading": { "type": "string" },
    "intro": { "type": "string" },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "score": { "type": "integer" },
          "team": { "type": "string" },
          "league": { "type": "string" },
          "center": { "type": "string" },
          "date": { "type": "string" },
          "bowlers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "scores": { "type": "array", "items": { "type": "integer" } },
                "total": { "type": "integer" }
              },
              "required": ["name"]
            }
          }
        },
        "required": ["title", "score"]
      }
    }
  },
  "required": ["heading", "records"]
}
