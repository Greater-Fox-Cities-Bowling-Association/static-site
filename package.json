{
  "name": "static-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "dotenv -e .env.development -- tinacms build --local --skip-cloud-checks && astro dev",
    "start": "dotenv -e .env.development -- tinacms build --local --skip-cloud-checks && astro dev",
    "build": "dotenv -e .env.production -- tinacms build --local --skip-cloud-checks && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "tina:build": "tinacms build --local --skip-cloud-checks",
    "tina:dev": "tinacms dev"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/tailwind": "^6.0.2",
    "@tinacms/cli": "^2.1.7",
    "@tinacms/toolkit": "^1.0.0",
    "astro": "^5.17.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "tinacms": "^3.5.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.9.3"
  }
}
